{
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist/client" }
    },
    {
      "src": "api/ssr.ts",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/assets/(.*)", "dest": "/assets/$1" },
    { "src": "/v-logo.svg", "dest": "/v-logo.svg" },
    { "src": "/favicon.ico", "dest": "/favicon.ico" },
    { "src": "/manifest.webmanifest", "dest": "/manifest.webmanifest" },
    { "src": "/sw.js", "dest": "/sw.js" },
    { "src": "/registerSW.js", "dest": "/registerSW.js" },
    { "src": "/(.*)", "dest": "/api/ssr.ts" }
  ]
}
